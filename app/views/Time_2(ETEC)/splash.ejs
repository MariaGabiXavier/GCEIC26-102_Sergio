<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>ETEC1 — Time_2</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #1a1a2e; display: flex; align-items: center; justify-content: center; min-height: 100vh; font-family: 'Segoe UI', sans-serif; }
    .splash { text-align: center; color: #fff; animation: fadeIn 1s ease; }
    .icon { font-size: 72px; margin-bottom: 20px; }
    h1 { font-size: 36px; letter-spacing: 4px; }
    p { color: #aaa; margin-top: 8px; font-size: 15px; }
    .bar { width: 200px; height: 4px; background: #333; border-radius: 2px; margin: 32px auto 0; overflow: hidden; }
    .fill { height: 100%; background: #e94560; border-radius: 2px; animation: load 2.5s ease forwards; }
    @keyframes load { from { width: 0 } to { width: 100% } }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(20px) } to { opacity: 1; transform: translateY(0) } }
  </style>
  <script>setTimeout(() => window.location = '/ETEC1/login', 3000);</script>
</head>
<body>
  <div class="splash">
    <div class="icon">⚖️</div>
    <h1>ETEC1</h1>
    <p>Encargos Trabalhistas · Empregada Doméstica</p>
    <p style="margin-top:4px; font-size:12px; color:#555">Time_2 · GCEIC26 · 2026</p>
    <div class="bar"><div class="fill"></div></div>
  </div>
</body>
</html>
