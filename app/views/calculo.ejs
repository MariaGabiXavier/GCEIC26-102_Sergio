<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
  <nav>
    <div >
      Olá, <strong><%= user.nome %></strong>
      <a href="/logout">Sair</a>
    </div>
  </nav>
  <h1>Calculadora de Markup - falta implementar esse front end</h1>
</body>
<script>

async function calcular() {
  console.log("valor"+ document.getElementById('altura').value);
  const altura1 = parseFloat(document.getElementById('altura').value);
  const largura1 = parseFloat(document.getElementById('largura').value);
  const payload = {
    altura: altura1,
    largura: largura1,
  };
  alert(JSON.stringify(payload));
  try {
    const res = await fetch('/calcular', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    
    const json = await res.json();
    
    alert(JSON.stringify(json));

    if (!json.success) { alert('Erro: ' + json.error); return; }

    const d = json.data;
    alert(d);
    document.getElementById('data').textContent = d.toString();
  } catch (e) {
    alert('Erro ao comunicar com o servidor: ' + e.message);
  } finally {

  }
}
</script>
</html>