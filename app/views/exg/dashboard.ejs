<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EXG — Dashboard</title>
  <link rel="stylesheet" href="/exg.css">
</head>
<body>
  <div class="layout">
    <%- include('nav') %>
    <main class="page-content">
      <h1 class="page-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Cotações do Dia
      </h1>

      <!-- Spinner: visível só quando não há dados ainda -->
      <div id="loadingState" style="<%= (currencies && currencies.length > 0) ? 'display:none' : 'display:flex;justify-content:center;padding:48px' %>">
        <span class="spinner dark"></span>
      </div>

      <!-- Grade sempre presente no DOM (e2e test depende disso) -->
      <div class="currency-grid" id="currencyGrid" style="margin-bottom:28px;<%= (!currencies || currencies.length === 0) ? 'display:none' : '' %>">
        <% if (currencies && currencies.length > 0) {
             var badgeColors = { USD: '#2E7D32', EUR: '#1565C0', GBP: '#6A1B9A', JPY: '#C62828', ARS: '#0277BD' };
             for (var i = 0; i < currencies.length; i++) { var c = currencies[i]; %>
          <a class="currency-card" href="/exg/exchange?currency=<%= c.codigo %>" title="Clique para converter">
            <div style="width:44px;height:44px;border-radius:50%;background:<%= badgeColors[c.codigo] || '#1a1a1a' %>;color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;letter-spacing:1px">
              <%= c.codigo %>
            </div>
            <div class="currency-code"><%= c.codigo %></div>
            <div class="currency-name"><%= c.nome %></div>
            <div>
              <div class="currency-rate-label">1 <%= c.codigo %> =</div>
              <div class="currency-rate">R$ <%= c.cotacao_brl.toLocaleString('pt-BR', {minimumFractionDigits:4,maximumFractionDigits:4}) %></div>
            </div>
            <div class="currency-spread">Spread <%= c.spread %></div>
          </a>
        <% } } %>
      </div>

      <!-- Card de dica -->
      <div id="infoCard" class="card" style="display:<%= (currencies && currencies.length > 0) ? 'flex' : 'none' %>;align-items:center;gap:16px;flex-wrap:wrap">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
        <div>
          <div style="font-weight:700;margin-bottom:4px">Como usar o EXG</div>
          <div style="color:var(--text-secondary);font-size:14px">
            Clique em uma moeda para ir direto ao simulador de câmbio, ou use o menu <strong>Converter</strong> para calcular valores com IOF e spread incluídos.
          </div>
        </div>
        <a href="/exg/exchange" class="btn btn-primary" style="margin-left:auto;white-space:nowrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3 4 7l4 4"/><path d="M4 7h16"/><path d="m16 21-4-4 4-4"/><path d="M20 17H4"/></svg>
          Converter agora
        </a>
      </div>
    </main>
  </div>

  <script>
    var COLORS = { USD: '#2E7D32', EUR: '#1565C0', GBP: '#6A1B9A', JPY: '#C62828', ARS: '#0277BD' };

    function renderCards(list) {
      var grid = document.getElementById('currencyGrid');
      grid.innerHTML = '';
      list.forEach(function(c) {
        var color = COLORS[c.codigo] || '#1a1a1a';
        var rate  = c.cotacao_brl.toLocaleString('pt-BR', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
        var card  = document.createElement('a');
        card.className = 'currency-card';
        card.href  = '/exg/exchange?currency=' + c.codigo;
        card.title = 'Clique para converter';
        card.innerHTML =
          '<div style="width:44px;height:44px;border-radius:50%;background:' + color + ';color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;letter-spacing:1px">' + c.codigo + '</div>' +
          '<div class="currency-code">' + c.codigo + '</div>' +
          '<div class="currency-name">' + c.nome + '</div>' +
          '<div><div class="currency-rate-label">1 ' + c.codigo + ' =</div><div class="currency-rate">R$ ' + rate + '</div></div>' +
          '<div class="currency-spread">Spread ' + c.spread + '</div>';
        grid.appendChild(card);
      });
      document.getElementById('loadingState').style.display = 'none';
      grid.style.display = '';
      document.getElementById('infoCard').style.display = 'flex';
    }

    // Se não há cards no DOM (server-side fetch falhou), busca client-side
    if (document.querySelectorAll('.currency-card').length === 0) {
      (async function fetchWithRetry(attempts) {
        try {
          var res  = await fetch('/exg/currencies');
          var list = await res.json();
          if (list && list.length > 0) {
            renderCards(list);
          } else if (attempts > 0) {
            setTimeout(function() { fetchWithRetry(attempts - 1); }, 800);
          } else {
            document.getElementById('loadingState').innerHTML =
              '<div style="text-align:center"><p style="color:var(--text-secondary);margin-bottom:16px">Não foi possível carregar as cotações.</p>' +
              '<a href="/exg/dashboard" class="btn btn-primary">Tentar novamente</a></div>';
          }
        } catch(e) {
          if (attempts > 0) {
            setTimeout(function() { fetchWithRetry(attempts - 1); }, 800);
          }
        }
      })(4);
    } else {
      document.getElementById('loadingState').style.display = 'none';
    }
  </script>
</body>
</html>
