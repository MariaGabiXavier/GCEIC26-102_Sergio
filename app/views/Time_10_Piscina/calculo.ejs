<!DOCTYPE html>
<html lang="pt-br">

<head>

  <meta charset="UTF-8">

  <title>Calculadora de Piscina</title>

  <link rel="stylesheet" href="/piscina.css">

</head>

<body>

  <nav>

    <a href="/piscina/calculo">Cálculo</a>
    <a href="/piscina/sobre">Sobre</a>
    <a href="/piscina/help">Help</a>
    <a href="/piscina/logout">Logout</a>

  </nav>

  <div class="container">

    <div class="card">

      <h1>Calculadora de Piscina</h1>

      <form method="POST" action="/piscina/calculo">

        <input
          type="number"
          step="0.1"
          name="comprimento"
          placeholder="Comprimento (m)"
          required
        >

        <input
          type="number"
          step="0.1"
          name="largura"
          placeholder="Largura (m)"
          required
        >

        <input
          type="number"
          step="0.1"
          name="profundidade"
          placeholder="Profundidade (m)"
          required
        >
        
        <div class="checkbox-group">

          <input
            type="checkbox"
            name="temIluminacao"
          >

          <label>
            Piscina com iluminação
          </label>

        </div>

        <br><br>

        <button type="submit">

          Calcular

        </button>

      </form>

      <% if (resultado && resultado.success) { %>

        <div class="resultado">

          <h2>Resultado</h2>

          <p>
            <strong>Volume:</strong>
            <%= resultado.data.volume_m3 %> m³
          </p>

          <p>
            <strong>Custo da Água:</strong>
            R$ <%= resultado.data.custo_agua %>
          </p>

          <p>
            <strong>Custo Elétrico:</strong>
            R$ <%= resultado.data.custo_eletrico %>
          </p>

          <p>
            <strong>Custo Hidráulico:</strong>
            R$ <%= resultado.data.custo_hidraulico %>
          </p>

          <p>
            <strong>Total Construção:</strong>
            R$ <%= resultado.data.total_construcao %>
          </p>

          <p>
            <strong>Manutenção Mensal:</strong>
            R$ <%= resultado.data.manutencao_mensal %>
          </p>

        </div>

      <% } %>

    </div>

  </div>

</body>

</html>