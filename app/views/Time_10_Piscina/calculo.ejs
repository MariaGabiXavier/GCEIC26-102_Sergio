<!DOCTYPE html>
<html lang="pt-br">

<head>

  <meta charset="UTF-8">

  <title>Calculadora de Piscina</title>

  <link rel="stylesheet" href="../../public/piscina.css">

</head>

<body>

  <nav>

    <a href="/piscina/calculo">Cálculo</a>
    <a href="/piscina/sobre">Sobre</a>
    <a href="/piscina/help">Help</a>
    <a href="/piscina/logout">Logout</a>

  </nav>

  <div class="container">

    <div class="card">

      <h1>Calculadora de Piscina</h1>

      <form method="POST" action="/piscina/calculo">
          
        <input
          type="number"
          id="comprimento"
          step="0.1"
          name="comprimento"
          placeholder="Comprimento (m)"
          required
        >

        <input
          type="number"
          id="largura"
          step="0.1"
          name="largura"
          placeholder="Largura (m)"
          required
        >

        <input
          type="number"
          id="profundidade"
          step="0.1"
          name="profundidade"
          placeholder="Profundidade (m)"
          required
        >
        
        <div class="checkbox-group">

          <input
            type="checkbox"
            name="temIluminacao"
          >

          <label>
            Piscina com iluminação
          </label>

        </div>

        <br><br>

        <button type="submit">

          Calcular

        </button>

      </form>

      <% if (resultado && resultado.success) { %>

      <div id="modalResultado" class="modal show">
        <div class="modal-content">

          <span class="close" onclick="document.getElementById('modalResultado').style.display='none'">&times;</span>

          <h2>Resultado</h2>

          <p><strong>Volume:</strong> <%= resultado.data.volume %> m³</p>

          <p><strong>Custo da Água:</strong> R$ <%= resultado.data.custoAgua %></p>

          <p><strong>Custo Elétrico:</strong> R$ <%= resultado.data.custoEletrico %></p>

          <p><strong>Custo Hidráulico:</strong> R$ <%= resultado.data.custoHidraulico %></p>

          <p><strong>Total Construção:</strong> R$ <%= resultado.data.total %></p>

          <p><strong>Manutenção Mensal:</strong> R$ <%= resultado.data.manutencao %></p>
        </div>
      </div>

      <% } %>

    </div>

  </div>

</body>

</html>