<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>ETEC1 — Calculadora</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; min-height: 100vh; }
    header { background: #1a1a2e; color: #fff; padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; }
    header h1 { font-size: 18px; }
    nav a { color: #aaa; text-decoration: none; margin-left: 20px; font-size: 14px; }
    nav a:hover { color: #fff; }
    .container { max-width: 800px; margin: 40px auto; padding: 0 20px; }
    .tabs { display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap; }
    .tab { padding: 10px 20px; border-radius: 8px; border: 2px solid #1a1a2e; background: #fff; cursor: pointer; font-size: 14px; color: #1a1a2e; }
    .tab.active { background: #1a1a2e; color: #fff; }
    .panel { display: none; background: #fff; border-radius: 12px; padding: 28px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
    .panel.active { display: block; }
    label { display: block; font-size: 13px; color: #555; margin-bottom: 4px; margin-top: 14px; }
    input, select { width: 100%; padding: 10px 14px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; }
    button.calc { margin-top: 20px; padding: 12px 28px; background: #1a1a2e; color: #fff; border: none; border-radius: 8px; font-size: 15px; cursor: pointer; }
    .resultado { margin-top: 24px; background: #f8f9fa; border-radius: 8px; padding: 20px; display: none; }
    .resultado h3 { margin-bottom: 12px; color: #1a1a2e; font-size: 15px; }
    .linha { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #eee; font-size: 14px; }
    .linha:last-child { border: none; font-weight: bold; color: #1a1a2e; }
  </style>
</head>
<body>
  <header>
    <h1>⚖️ ETEC1 — Encargos Trabalhistas</h1>
    <nav>
      <a href="/ETEC1/sobre">Sobre</a>
      <a href="/ETEC1/help">Ajuda</a>
      <a href="/ETEC1/logout">Sair</a>
    </nav>
  </header>

  <div class="container">
    <div class="tabs">
      <button class="tab active" onclick="showTab('salario', this)">💰 Salário Mensal</button>
      <button class="tab" onclick="showTab('ferias', this)">🏖️ Férias</button>
      <button class="tab" onclick="showTab('rescisao', this)">📄 Rescisão</button>
      <button class="tab" onclick="showTab('decimo', this)">🎄 13º Salário</button>
    </div>

    <!-- SALÁRIO -->
    <div id="panel-salario" class="panel active">
      <label>Salário Bruto (R$)</label>
      <input type="number" id="sal-salario" min="0" step="0.01" placeholder="Ex: 2000.00">
      <button class="calc" onclick="calcular('salario')">Calcular</button>
      <div class="resultado" id="res-salario"></div>
    </div>

    <!-- FÉRIAS -->
    <div id="panel-ferias" class="panel">
      <label>Salário Bruto (R$)</label>
      <input type="number" id="fer-salario" min="0" step="0.01" placeholder="Ex: 2000.00">
      <button class="calc" onclick="calcular('ferias')">Calcular</button>
      <div class="resultado" id="res-ferias"></div>
    </div>

    <!-- RESCISÃO -->
    <div id="panel-rescisao" class="panel">
      <label>Salário Bruto (R$)</label>
      <input type="number" id="res-salario-val" min="0" step="0.01" placeholder="Ex: 2000.00">
      <label>Meses Trabalhados</label>
      <input type="number" id="res-meses" min="1" max="600" placeholder="Ex: 24">
      <label>Motivo da Demissão</label>
      <select id="res-motivo">
        <option value="sem_justa_causa">Sem Justa Causa</option>
        <option value="justa_causa">Justa Causa</option>
        <option value="pedido_demissao">Pedido de Demissão</option>
      </select>
      <button class="calc" onclick="calcular('rescisao')">Calcular</button>
      <div class="resultado" id="res-rescisao"></div>
    </div>

    <!-- 13º -->
    <div id="panel-decimo" class="panel">
      <label>Salário Bruto (R$)</label>
      <input type="number" id="dec-salario" min="0" step="0.01" placeholder="Ex: 2000.00">
      <label>Meses Trabalhados no Ano (1–12)</label>
      <input type="number" id="dec-meses" min="1" max="12" placeholder="Ex: 12">
      <button class="calc" onclick="calcular('decimoterceiro')">Calcular</button>
      <div class="resultado" id="res-decimo"></div>
    </div>
  </div>

  <script>
    const API = '/ETEC1';
    const fmt = v => 'R$ ' + parseFloat(v).toFixed(2).replace('.', ',');

    function showTab(name, btn) {
      document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.getElementById('panel-' + name).classList.add('active');
      btn.classList.add('active');
    }

    const labels = {
      salarioBruto: 'Salário Bruto', inss: 'INSS (empregada)', fgts: 'FGTS (8%)',
      patronal: 'INSS Patronal (8%)', salarioLiquido: 'Salário Líquido', custoTotalEmpregador: 'Custo Total ao Empregador',
      ferias: 'Férias', tercoConstitucional: '1/3 Constitucional', inssFerias: 'INSS sobre Férias',
      fgtsFerias: 'FGTS Férias', totalBruto: 'Total Bruto', totalLiquido: 'Total Líquido',
      saldoSalario: 'Saldo de Salário', decimoTerceiro: '13º Proporcional',
      feriasProporcional: 'Férias Proporcionais', avisoPrevio: 'Aviso Prévio',
      saldoFGTS: 'Saldo FGTS', multaFGTS: 'Multa FGTS', totalRescisao: 'Total da Rescisão',
      decimoBruto: '13º Bruto', decimoLiquido: '13º Líquido',
    };

    async function calcular(tipo) {
      let body = {};
      let resId = '';
      if (tipo === 'salario') {
        body = { salario: document.getElementById('sal-salario').value }; resId = 'res-salario';
      } else if (tipo === 'ferias') {
        body = { salario: document.getElementById('fer-salario').value }; resId = 'res-ferias';
      } else if (tipo === 'rescisao') {
        body = { salario: document.getElementById('res-salario-val').value, mesesTrabalhados: document.getElementById('res-meses').value, motivoDemissao: document.getElementById('res-motivo').value }; resId = 'res-rescisao';
      } else if (tipo === 'decimoterceiro') {
        body = { salario: document.getElementById('dec-salario').value, mesesTrabalhados: document.getElementById('dec-meses').value }; resId = 'res-decimo';
      }
      try {
        const r = await fetch(`${API}/${tipo}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
        const d = await r.json();
        const el = document.getElementById(resId);
        if (d.erro) { el.innerHTML = `<p style="color:red">${d.erro}</p>`; el.style.display = 'block'; return; }
        const rows = Object.entries(d).filter(([k]) => labels[k]).map(([k,v]) => `<div class="linha"><span>${labels[k]}</span><span>${isNaN(v) ? v : fmt(v)}</span></div>`).join('');
        el.innerHTML = `<h3>Resultado</h3>${rows}`;
        el.style.display = 'block';
      } catch(e) { alert(e); }
    }
  </script>
</body>
</html>
