<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>ETEC1 — Sobre</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; }
    header { background: #1a1a2e; color: #fff; padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; }
    header h1 { font-size: 18px; }
    nav a { color: #aaa; text-decoration: none; margin-left: 20px; font-size: 14px; }
    nav a:hover { color: #fff; }
    .container { max-width: 700px; margin: 40px auto; padding: 0 20px; }
    .card { background: #fff; border-radius: 12px; padding: 32px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); margin-bottom: 20px; }
    h2 { color: #1a1a2e; margin-bottom: 20px; }

    /* Foto do grupo */
    .foto-grupo {
      width: 100%;
      max-height: 280px;
      object-fit: cover;
      border-radius: 10px;
      margin-bottom: 24px;
      background: #e0e0e0;
      display: block;
    }
    .foto-placeholder {
      width: 100%;
      height: 220px;
      border-radius: 10px;
      background: #1a1a2e;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 48px;
      margin-bottom: 24px;
      color: #fff;
      letter-spacing: 12px;
    }

    /* Lista de membros */
    .members { display: flex; flex-direction: column; gap: 10px; }
    .member { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: #f8f9fa; border-radius: 8px; }
    .member-name { font-size: 15px; font-weight: 600; color: #1a1a2e; }
    .member-ra { font-size: 13px; color: #888; }

    /* Info do projeto */
    .info p { margin-bottom: 8px; font-size: 14px; color: #555; line-height: 1.6; }
  </style>
</head>
<body>
<header>
  <h1>⚖️ ETEC1 — Encargos Trabalhistas</h1>
  <nav>
    <a href="/ETEC1/calculo">Calculadora</a>
    <a href="/ETEC1/help">Ajuda</a>
    <a href="/ETEC1/logout">Sair</a>
  </nav>
</header>

<div class="container">
  <div class="card">
    <h2>👥 Nossa Equipe — Time_2</h2>

    <img src="/img/Time_2(ETEC).JPG" alt="Foto do grupo Time_2" class="foto-grupo">

    <div class="members">
      <div class="member">
        <span class="member-name">Jean Yuki Kimura</span>
        <span class="member-ra">RA: 24008214</span>
      </div>
      <div class="member">
        <span class="member-name">Jhenifer Laís Barbosa</span>
        <span class="member-ra">RA: 24014979</span>
      </div>
      <div class="member">
        <span class="member-name">João Pedro Duarte Giatti</span>
        <span class="member-ra">RA: 24019083</span>
      </div>
    </div>
  </div>

  <div class="card info">
    <h2>📌 Sobre o Projeto</h2>
    <p><strong>Disciplina:</strong> Gerência de Configuração, Entrega e Integração Contínua</p>
    <p><strong>Professor:</strong> Sérgio Marques</p>
    <p><strong>Tema:</strong> Cálculo de Encargos Trabalhistas — Empregada Doméstica</p>
    <p><strong>Endpoint API:</strong> /ETEC1</p>
    <p><strong>Repositório:</strong> github.com/sergiolmm-pucc/GCEIC26</p>
    <p><strong>Semestre:</strong> 1º Semestre de 2026</p>
  </div>
</div>
</body>
</html>
