<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Markup Calc</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, Helvetica, sans-serif;
    }

    body {
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: linear-gradient(135deg, #14532d, #166534, #22c55e);
      overflow: hidden;
    }

    .background-circle {
      position: absolute;
      border-radius: 50%;
      background: rgba(255,255,255,0.08);
      animation: float 8s infinite ease-in-out;
    }

    .circle-1 {
      width: 300px;
      height: 300px;
      top: -100px;
      left: -80px;
    }

    .circle-2 {
      width: 220px;
      height: 220px;
      bottom: -70px;
      right: -50px;
      animation-delay: 2s;
    }

    .circle-3 {
      width: 140px;
      height: 140px;
      top: 15%;
      right: 15%;
      animation-delay: 4s;
    }

    .splash-container {
      position: relative;
      width: 360px;
      padding: 45px 35px;
      border-radius: 28px;
      backdrop-filter: blur(12px);
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.15);
      text-align: center;
      color: white;
      box-shadow: 0 10px 40px rgba(0,0,0,0.25);
      animation: fadeIn 1s ease;
    }

    .logo {
      width: 110px;
      height: 110px;
      margin: 0 auto 25px;
      border-radius: 28px;
      background: rgba(255,255,255,0.15);
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 3rem;
      border: 1px solid rgba(255,255,255,0.2);
      box-shadow: 0 6px 20px rgba(0,0,0,0.15);
      animation: pulse 2s infinite;
    }

    h1 {
      font-size: 2.2rem;
      margin-bottom: 10px;
      font-weight: 700;
      letter-spacing: 1px;
    }

    h1 span {
      color: #dcfce7;
    }

    p {
      font-size: 1rem;
      opacity: 0.9;
      margin-bottom: 30px;
      line-height: 1.5;
    }

    .loading {
      width: 100%;
      height: 10px;
      background: rgba(255,255,255,0.2);
      border-radius: 999px;
      overflow: hidden;
      position: relative;
    }

    .loading::before {
      content: "";
      position: absolute;
      width: 40%;
      height: 100%;
      background: white;
      border-radius: 999px;
      animation: loading 2s infinite ease-in-out;
    }

    .version {
      margin-top: 22px;
      font-size: 0.8rem;
      opacity: 0.7;
      letter-spacing: 1px;
    }
    .navbar {
  width: 100%;
  height: 75px;
  padding: 0 40px;

  display: flex;
  justify-content: space-between;
  align-items: center;

  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(12px);

  border-bottom: 1px solid rgba(255,255,255,0.1);

  position: fixed;
  top: 0;
  left: 0;

  z-index: 1000;
}

.logo {
  font-size: 1.4rem;
  font-weight: bold;
  color: white;
  letter-spacing: 1px;
}

.logo span {
  color: #bbf7d0;
}

.nav-links {
  list-style: none;

  display: flex;
  align-items: center;
  gap: 30px;
}
.navbar .logout-link {
      text-decoration: none;
      color: white;
      font-size: 1rem;
      font-weight: 500;
      transition: 0.3s;
      position: relative;
    }

    .navbar .logout-link:hover {
      color: #bbf7d0;
    }

    .navbar .logout-link::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: -6px;
      width: 0%;
      height: 2px;
      background: #bbf7d0;
      transition: 0.3s;
    }

    .navbar .logout-link:hover::after {
      width: 100%;
    }
.navbar .user-info {
      font-size: 1rem;
      color: white;
      letter-spacing: 0.5px;
    }

    .navbar .user-info strong {
      color: #bbf7d0;
    }
.nav-links a {
  text-decoration: none;
  color: white;
  font-size: 1rem;
  font-weight: 500;

  transition: 0.3s;
  position: relative;
}

.nav-links a:hover {
  color: #bbf7d0;
}

.nav-links a::after {
  content: "";

  position: absolute;
  left: 0;
  bottom: -6px;

  width: 0%;
  height: 2px;

  background: #bbf7d0;

  transition: 0.3s;
}

    .nav-links a:hover::after {
      width: 100%;
    }

    .dropdown {
      position: relative;
      display: inline-block;
    }

    .dropdown-content {
      display: none;
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 12px;
      min-width: 220px;
      padding: 8px 0;
      box-shadow: 0 8px 25px rgba(0,0,0,0.25);
      z-index: 1001;
      animation: fadeIn 0.2s ease;
    }

    .dropdown-content a {
      display: block;
      padding: 10px 20px;
      text-decoration: none;
      color: white;
      font-size: 0.9rem;
      font-weight: 500;
      transition: 0.3s;
      text-align: left;
    }

    .dropdown-content a::after {
      display: none;
    }

    .dropdown-content a:hover {
      background: rgba(255,255,255,0.1);
      color: #bbf7d0;
    }

    .dropdown:hover .dropdown-content {
      display: block;
    }

    .dropdown .nav-link {
      cursor: pointer;
    }

    @keyframes loading {
      0% {
        left: -40%;
      }
      100% {
        left: 100%;
      }
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.05);
      }
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes float {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(20px);
      }
    }
  </style>
</head>

<body>

  <div class="background-circle circle-1"></div>
  <div class="background-circle circle-2"></div>
  <div class="background-circle circle-3"></div>
<nav class="navbar">


    <ul class="nav-links">
      <% if (user == undefined) { %>
      <li><a href="/markup/login">Login</a></li>
      <% }; %>
      <li><a href="/markup/sobre">Sobre</a></li>
      <li><a href="/markup/help">Help</a></li>
      <li class="dropdown">
        <a class="nav-link">Calcular ▾</a>
        <div class="dropdown-content">
          <a href="/markup/preco-venda">Calcular Preço de Venda</a>
          <a href="/markup/desconto">Calcular Desconto</a>
          <a href="/markup/markup-multiplicador">CalcularMarkup Multiplicador</a>
        </div>
      </li>
    </ul>
    <div class="user-info">
  <% if (user) { %>
    Olá, <strong><%= user.nome %></strong>
  <% }; %>
</div>
<% if (user) { %>
<a href="/markup/logout" class="logout-link">Sair</a>
<% }; %>
  </nav>
  <div class="splash-container">

    <div class="logo">
      📈
    </div>

    <h1>Markup <span>Calc</span></h1>

    <p>
      Sistema inteligente para cálculo de preço de venda,
      margem de lucro e markup empresarial.
    </p>

    <div class="loading"></div>

    <div class="version">
      versão 1.0
    </div>

  </div>

</body>
</html>

